DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=wijkconnect"
NEXTAUTH_URL="https://wijkconnect.vercel.app"
NEXTAUTH_SECRET="GENEREER_EEN_UNIEK_LANG_SECRET"
MONITORING_PSEUDONYM_SECRET="GENEREER_EEN_APART_UNIEK_LANG_SECRET"
# Publieke basis-URL voor persoonlijke vragenlijstlinks.
APP_URL="https://wijkconnect.vercel.app"
# Native vragenlijsten: 32-byte mastersleutel (base64 of 64 hex-tekens) en apart tokensecret.
# Roteer deze niet zonder her-encryptie; bewaar de sleutel tot versleutelde contactdata is verwijderd.
SURVEY_CONTACT_ENCRYPTION_KEY="GENEREER_32_BYTES_EN_CODEER_ALS_BASE64"
SURVEY_TOKEN_SECRET="GENEREER_EEN_APART_UNIEK_LANG_SECRET_VAN_MINIMAAL_32_TEKENS"
# Transactionele e-mail via Brevo. Gebruik een geverifieerde afzender op het eigen domein.
# Tijdelijke testafzender; vervang deze vóór patiëntgebruik door een project- of praktijkdomein.
BREVO_API_KEY="ALLEEN_IN_VERCEL_OPSLAAN"
BREVO_SENDER_EMAIL="vragenlijst@luuksmeekens.nl"
BREVO_SENDER_NAME="Luuk Smeekens"
BREVO_REPLY_TO_EMAIL="luuk.smeekens@outlook.com"
# Brevo verstuurt dit via de officiële webhook Bearer-auth; minimaal 32 willekeurige tekens.
BREVO_WEBHOOK_SECRET="GENEREER_EEN_UNIEK_LANG_RANDOM_SECRET"
# Vercel zet deze waarde als Bearer-token op cronverzoeken.
CRON_SECRET="GENEREER_EEN_ANDER_UNIEK_LANG_RANDOM_SECRET"
SURVEY_REMINDER_AFTER_DAYS="4"
# Alleen tijdelijk gebruiken voor het eenmalige herstelcommando `npm run admin:reset`.
ADMIN_RESET_EMAIL="admin@wijkconnect.nl"
ADMIN_RESET_PASSWORD="MINIMAAL_14_TEKENS_EN_UNIEK"
# Alleen nodig wanneer prisma/seed.ts of create-pilot-observers.js bewust wordt uitgevoerd.
SEED_PASSWORD="UNIEK_TIJDelijk_WACHTWOORD_VAN_MINIMAAL_12_TEKENS"
